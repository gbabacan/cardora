// Prisma schema for Cardora
// Based on PRD.MD data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User model (organizers/admins; optional for contributors)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  authProvider String   @default("email") @map("auth_provider")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  boards       Board[]
  posts        Post[]

  @@map("users")
}

// Board model
model Board {
  id               String    @id @default(cuid())
  workspaceId      String?   @map("workspace_id")
  title            String
  occasionType     String    @map("occasion_type") // birthday, farewell, thank-you, etc.
  themeId          String?   @map("theme_id")
  privacyType      String    @default("unlisted") @map("privacy_type") // public, unlisted, password
  passwordHash     String?   @map("password_hash")
  status           String    @default("draft") // draft, active, delivered, archived
  deliveryDatetime DateTime? @map("delivery_datetime")
  timezone         String    @default("UTC")
  recipientName    String?   @map("recipient_name")
  recipientEmail   String?   @map("recipient_email")
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  createdBy User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  posts     Post[]
  invites   Invite[]
  payments  Payment[]

  @@index([createdByUserId])
  @@index([status])
  @@index([occasionType])
  @@map("boards")
}

// Post model (contributions to a board)
model Post {
  id               String   @id @default(cuid())
  boardId          String   @map("board_id")
  authorName       String   @map("author_name")
  authorUserId     String?  @map("author_user_id")
  messageText      String   @db.Text @map("message_text")
  mediaType        String   @default("none") @map("media_type") // none, image, gif, video
  mediaUrl         String?  @map("media_url")
  moderationStatus String   @default("approved") @map("moderation_status") // approved, pending, rejected
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  board  Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([authorUserId])
  @@map("posts")
}

// Invite model (contributor invitations)
model Invite {
  id            String    @id @default(cuid())
  boardId       String    @map("board_id")
  email         String
  token         String    @unique
  status        String    @default("sent") // sent, opened, contributed
  sentAt        DateTime  @default(now()) @map("sent_at")
  openedAt      DateTime? @map("opened_at")
  contributedAt DateTime? @map("contributed_at")

  // Relations
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([token])
  @@map("invites")
}

// Payment model
model Payment {
  id        String   @id @default(cuid())
  boardId   String?  @map("board_id")
  provider  String   @default("stripe")
  amount    Int // in cents
  currency  String   @default("usd")
  status    String // pending, succeeded, failed, refunded
  metadata  Json? // store additional payment info
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  board Board? @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([status])
  @@map("payments")
}

// Audit Event model (for tracking actions)
model AuditEvent {
  id         String   @id @default(cuid())
  actorUserId String? @map("actor_user_id")
  entityType String   @map("entity_type") // board, post, invite, payment
  entityId   String   @map("entity_id")
  action     String // created, updated, deleted, delivered
  metadata   Json? // additional context
  timestamp  DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_events")
}